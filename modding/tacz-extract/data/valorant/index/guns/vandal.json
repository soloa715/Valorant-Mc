{
    // 枪械的显示名称，支持本地化
    "name": "valorant.gun.vandal.name",
    // 枪械效果文件
    "display": "valorant:vandal_display",
    // 枪械参数文件
    "data": "valorant:vandal_data",
    // 枪械文本提示
    "tooltip": "valorant.gun.vandal.desc",
    // 枪械种类，用于创造标签栏归类。
    // 所有可用分类：pistol(手枪) sniper(狙击枪) rifle(步枪) shotgun(霰弹枪) smg(冲锋枪) 
    //             mg(机枪) rpg(火箭筒)
    "type": "rifle",
    // 枪械的物品类型，决定枪械的逻辑，如开火、装填等，默认是 modern_kinetic (现代动能枪械)
    "item_type": "modern_kinetic",
    // 排序数，决定了在创造模式标签页中的顺序
    // 数字越小，优先级越高
    "sort": 1
}